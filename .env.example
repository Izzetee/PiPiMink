# PiPiMink environment variables example
# Copy this file to .env and fill in your values

# ─── Provider configuration ────────────────────────────────────────────────
# Providers are configured via providers.json (see providers.example.json).
# API keys are referenced by name in providers.json and resolved here.
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ── Azure AI Foundry ────────────────────────────────────────────────────────
# One env var per model — reference via "api_key_env" inside "model_configs" in providers.json.
# Add as many models as you like; just add a new entry in model_configs + a new key here.
#
# Serverless-API models (Mistral, Llama, Phi, Cohere, DeepSeek, …):
AZURE_FOUNDRY_MISTRAL_LARGE_API_KEY=your-key-here
AZURE_FOUNDRY_PHI4_API_KEY=your-key-here
AZURE_FOUNDRY_LLAMA_API_KEY=your-key-here
# Anthropic models via Azure (Claude family):
AZURE_FOUNDRY_CLAUDE_OPUS_API_KEY=your-key-here
# Project-scoped OpenAI models:
AZURE_FOUNDRY_GPT4O_API_KEY=your-key-here
# Legacy Azure OpenAI deployment (single model per deployment, no model_configs needed):
AZURE_GPT4O_API_KEY=your-azure-gpt4o-key-here

# ─── Routing behaviour ─────────────────────────────────────────────────────
# Name of the provider used to make routing decisions (must match a name in providers.json)
MODEL_SELECTION_PROVIDER=openai
# Model within that provider used as the meta-router
MODEL_SELECTION_MODEL=gpt-4-turbo
# Fallback model when routing fails
DEFAULT_CHAT_MODEL=gpt-4-turbo

# ─── Routing decision cache ────────────────────────────────────────────────
SELECTION_CACHE_ENABLED=true
SELECTION_CACHE_TTL=2m
SELECTION_CACHE_MAX_ENTRIES=1000
SELECTION_CACHE_STATS_LOG_INTERVAL=1m

# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@pipimink-postgres:5432/mydatabase?sslmode=disable
DATABASE_MAX_CONNECTIONS=25
DATABASE_MAX_IDLE_CONNECTIONS=5
DATABASE_CONNECTION_MAX_LIFETIME=30m

# ─── Server ────────────────────────────────────────────────────────────────
ADMIN_API_KEY=your-admin-key-here
PORT=8080

# ─── Benchmarking ──────────────────────────────────────────────────────────
# Enable benchmark support (required to use POST /models/benchmark)
BENCHMARK_ENABLED=false
# Automatically run benchmarks on a schedule
BENCHMARK_SCHEDULE_ENABLED=false
# How often to run scheduled benchmarks (Go duration: 24h, 12h, 6h …)
BENCHMARK_SCHEDULE_INTERVAL=24h
# Provider + model used as the LLM judge for subjective tasks (coding, creative writing, etc.)
# Defaults to MODEL_SELECTION_PROVIDER / MODEL_SELECTION_MODEL if not set
BENCHMARK_JUDGE_PROVIDER=
BENCHMARK_JUDGE_MODEL=
# Max number of models benchmarked in parallel
BENCHMARK_CONCURRENCY=3

# ─── Observability (OpenTelemetry + OpenMetrics) ───────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=pipimink
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4318
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_TRACE_SAMPLE_RATIO=1.0